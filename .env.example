# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider — choose "gemini" (default), "openai", or "openrouter"
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini

# ── Option A: Google Gemini ───────────────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── Option B: OpenAI ─────────────────────────────────────────────────────────
# Get an API key at: https://platform.openai.com/api-keys
# Set LLM_PROVIDER=openai above, then fill this in:
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Option C: OpenRouter ──────────────────────────────────────────────────────
# Get a free API key at: https://openrouter.ai/keys
# Set LLM_PROVIDER=openrouter above, then fill this in:
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenRouter model (default: meta-llama/llama-3.3-70b-instruct:free)
# Browse available models at: https://openrouter.ai/models
# Filter by "Free" and "Tools" support. Verified working examples:
#   meta-llama/llama-3.3-70b-instruct:free   ← default, free, supports tool calling
#   mistralai/mistral-small-3.1-24b-instruct:free
#   google/gemini-2.0-flash-001              ← stable (not :free, may incur cost)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─────────────────────────────────────────────────────────────────────────────
# Server config
# ─────────────────────────────────────────────────────────────────────────────

# Optional: Server port (default: 3000)
# PORT=3000

# Optional: SQLite database file path (default: ./data/tasks.db)
# DB_PATH=./data/tasks.db

# Optional: App's public URL — sent as HTTP-Referer to OpenRouter
# APP_URL=http://localhost:3000
